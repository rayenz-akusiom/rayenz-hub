{
  "name": "rayenz-hub",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run tests/unit",
    "test:api": "vitest run tests/api",
    "test:web": "vitest run --config vitest.web.config.ts",
    "test:coverage": "vitest run --config vitest.coverage.config.ts --coverage",
    "test:coverage:full": "vitest run --config vitest.coverage.full.config.ts --coverage",
    "test:web:coverage": "vitest run --config vitest.web.config.ts --coverage",
    "dev:web": "npm run dev -w @rayenz-hub/web",
    "build:web": "npm run build -w @rayenz-hub/web",
    "publish:hub": "npm run build:web && node scripts/publish-hub-hint.mjs",
    "test:unit:watch": "vitest tests/unit",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "extract:suggestion-fixture": "node tests/scripts/extract-suggestion-fixture.mjs",
    "deploy:hub": "git subtree push --prefix=rayenz-hub hub-prod main",
    "init:local-db": "node scripts/create-local-hub-table.mjs",
    "start:dynamodb:persist": "docker run --rm -p 8000:8000 -u root -v rayenz-hub-dynamodb:/home/dynamodblocal/data amazon/dynamodb-local -jar DynamoDBLocal.jar -sharedDb -dbPath /home/dynamodblocal/data",
    "start:minio:persist": "docker run --rm -p 9000:9000 -e MINIO_ROOT_USER=local -e MINIO_ROOT_PASSWORD=localpass1 -v rayenz-hub-minio:/data minio/minio server /data",
    "build:api": "sam build --template-file infra/template.yaml --build-in-source && node scripts/copy-api-lambda-assets.mjs",
    "start:api": "npm run build:api && sam local start-api --template .aws-sam/build/template.yaml --env-vars infra/env.local.json --port 3000",
    "deploy:api": "npm run build:api && sam deploy --config-file infra/samconfig.toml",
    "deploy:api:guided": "npm run build:api && sam deploy --guided --config-file infra/samconfig.toml",
    "test:api:deployed": "vitest run tests/api/deployed.contract.test.ts",
    "migrate:user-partition": "tsx scripts/migrate-user-partition.ts",
    "seed:local-library": "tsx scripts/seed-local-library.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.7",
    "happy-dom": "^17.4.4",
    "jsdom": "^26.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
